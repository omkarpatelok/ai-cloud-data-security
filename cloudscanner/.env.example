# Copy to ".env" in this folder (same level as pom.xml). ".env" is gitignored.
#
# After editing .env, start the app with either:
#   ./mvnw spring-boot:run
#   ./run-with-env.sh
# The Spring Boot app also loads ".env" automatically from the cloudscanner directory.

# Required for IAM user access keys (or use AWS_PROFILE + ~/.aws/credentials instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Must match aws.region in src/main/resources/application.yml
AWS_DEFAULT_REGION=ap-south-1

# Optional: named profile from ~/.aws/credentials (leave keys empty above if you use this only in shell)
# AWS_PROFILE=default

# Optional: temporary credentials (STS)
# AWS_SESSION_TOKEN=
